    "Спрашивает один и тот же домен у нескольких DNS-резолверов и сравнивает ответы бок о бок. Помогает заметить подмену или расхождения.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يستعلم عن النطاق نفسه من عدة محلّلات DNS ويقارن الاستجابات جنباً إلى جنب. يساعد على ملاحظة التزوير أو الاختلافات."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fragt dieselbe Domain bei mehreren DNS-Resolvern ab und vergleicht die Antworten nebeneinander. Hilft, Fälschungen oder Abweichungen zu erkennen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Queries the same domain from several DNS resolvers and compares the responses side by side. Helps spot spoofing or discrepancies."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Consulta el mismo dominio a varios resolutores DNS y compara las respuestas en paralelo. Ayuda a detectar falsificaciones o discrepancias."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Interroge le même domaine auprès de plusieurs résolveurs DNS et compare les réponses côte à côte. Aide à repérer une falsification ou des divergences."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "एक ही डोमेन को कई DNS रिज़ॉल्वरों से पूछता है और उत्तरों की साथ-साथ तुलना करता है। छेड़छाड़ या भिन्नता देखने में मदद करता है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Interroga lo stesso dominio su più resolver DNS e confronta le risposte una accanto all'altra. Aiuta a notare alterazioni o discrepanze."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "同じドメインを複数の DNS リゾルバに問い合わせ、応答を並べて比較します。改ざんや不一致に気づくのに役立ちます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "여러 DNS 리졸버에 동일한 도메인을 조회하고 응답을 나란히 비교합니다. 변조나 불일치를 발견하는 데 유용합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Consulta o mesmo domínio em vários resolvedores DNS e compara as respostas lado a lado. Ajuda a notar adulteração ou divergências."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aynı alan adını birden fazla DNS çözümleyicisine sorar ve yanıtları yan yana karşılaştırır. Sahtekârlığı veya tutarsızlıkları fark etmeye yardımcı olur."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "向多个 DNS 解析器查询同一域名并并排对比响应。帮助发现篡改或差异。"
          }
        }
      }
    },
