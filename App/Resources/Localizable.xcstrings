    "Резолверы вернули разные адреса — возможна подмена или split-horizon.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أعادت المحلّلات عناوين مختلفة — قد يكون تزويراً أو split-horizon."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Resolver haben unterschiedliche Adressen zurückgegeben – möglicherweise Fälschung oder Split-Horizon."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Resolvers returned different addresses — spoofing or split-horizon is possible."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los resolutores devolvieron direcciones distintas: posible falsificación o split-horizon."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les résolveurs ont renvoyé des adresses différentes — une falsification ou un split-horizon est possible."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "रिज़ॉल्वरों ने भिन्न पते लौटाए — संभवतः छेड़छाड़ या split-horizon।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I resolver hanno restituito indirizzi diversi — possibile alterazione o split-horizon."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "リゾルバが異なるアドレスを返しました — 改ざんまたは split-horizon の可能性があります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "리졸버들이 서로 다른 주소를 반환했습니다 — 변조 또는 split-horizon일 수 있습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Os resolvedores retornaram endereços diferentes — possível adulteração ou split-horizon."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Çözümleyiciler farklı adresler döndürdü — sahtekârlık veya split-horizon olabilir."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "各解析器返回了不同的地址 — 可能存在篡改或 split-horizon。"
          }
        }
      }
    },
