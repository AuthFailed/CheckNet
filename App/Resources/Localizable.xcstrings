    "Анализ Wi-Fi: уровень сигнала, канал, роуминг. Ограничено политиками iOS.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تحليل Wi-Fi: قوة الإشارة، القناة، التجوال. مقيّد بسياسات iOS."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wi-Fi-Analyse: Signalstärke, Kanal, Roaming. Durch iOS-Richtlinien eingeschränkt."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Wi-Fi analysis: signal strength, channel, roaming. Limited by iOS policies."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Análisis de Wi-Fi: nivel de señal, canal, roaming. Limitado por las políticas de iOS."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Analyse Wi-Fi : niveau du signal, canal, itinérance. Limité par les règles d'iOS."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Wi-Fi विश्लेषण: सिग्नल स्तर, चैनल, रोमिंग। iOS नीतियों द्वारा सीमित।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Analisi Wi-Fi: intensità del segnale, canale, roaming. Limitato dalle policy di iOS."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Wi-Fi 解析：信号強度・チャネル・ローミング。iOS のポリシーにより制限されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Wi-Fi 분석: 신호 강도, 채널, 로밍. iOS 정책에 의해 제한됩니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Análise de Wi-Fi: intensidade do sinal, canal, roaming. Limitado pelas políticas do iOS."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Wi-Fi analizi: sinyal gücü, kanal, dolaşım. iOS politikalarıyla sınırlıdır."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Wi-Fi 分析：信号强度、信道、漫游。受 iOS 策略限制。"
          }
        }
      }
    },
