    "Импорт только добавляет хосты — существующие записи не изменяются и не удаляются.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الاستيراد يضيف المضيفين فقط — لا يغيّر السجلات الحالية ولا يحذفها."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Import fügt nur Hosts hinzu – vorhandene Einträge werden weder geändert noch gelöscht."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Import only adds hosts — existing entries are never changed or deleted."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La importación solo añade hosts: las entradas existentes no se modifican ni se eliminan."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L’importation ne fait qu’ajouter des hôtes : les entrées existantes ne sont ni modifiées ni supprimées."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इंपोर्ट केवल होस्ट जोड़ता है — मौजूदा प्रविष्टियाँ न बदली जाती हैं, न हटाई जाती हैं।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L’importazione aggiunge solo host: le voci esistenti non vengono modificate né eliminate."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "読み込みではホストが追加されるだけです。既存の項目は変更も削除もされません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "가져오기는 호스트를 추가하기만 해요. 기존 항목은 변경되거나 삭제되지 않아요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A importação apenas adiciona hosts: os registros existentes não são alterados nem removidos."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
