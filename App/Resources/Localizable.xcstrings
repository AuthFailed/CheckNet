    "Измеряет рост задержки под нагрузкой (bufferbloat). Требует нагрузочного сервера.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يقيس ارتفاع التأخير تحت الحمل (bufferbloat). يتطلب خادم تحميل."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Misst den Anstieg der Latenz unter Last (Bufferbloat). Erfordert einen Lastserver."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Measures latency increase under load (bufferbloat). Requires a load server."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mide el aumento de latencia bajo carga (bufferbloat). Requiere un servidor de carga."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mesure l'augmentation de la latence sous charge (bufferbloat). Nécessite un serveur de charge."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "लोड के तहत विलंब वृद्धि (bufferbloat) मापता है। इसके लिए लोड सर्वर आवश्यक है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Misura l'aumento della latenza sotto carico (bufferbloat). Richiede un server di carico."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "負荷時の遅延増加（bufferbloat）を測定します。負荷サーバーが必要です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "부하 상태에서의 지연 증가(bufferbloat)를 측정합니다. 부하 서버가 필요합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Mede o aumento da latência sob carga (bufferbloat). Requer um servidor de carga."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yük altında gecikme artışını (bufferbloat) ölçer. Bir yük sunucusu gerektirir."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "测量负载下延迟的增长（缓冲膨胀）。需要负载服务器。"
          }
        }
      }
    },
    "Измеряет скорость загрузки и отдачи через iperf3-серверы или HTTP. Показывает реальную пропускную способность канала.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يقيس سرعة التنزيل والرفع عبر خوادم iperf3 أو HTTP. يعرض عرض النطاق الفعلي للقناة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Misst die Download- und Upload-Geschwindigkeit über iperf3-Server oder HTTP. Zeigt die tatsächliche Bandbreite der Verbindung."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Measures download and upload speed via iperf3 servers or HTTP. Shows the real bandwidth of your connection."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mide la velocidad de descarga y subida mediante servidores iperf3 o HTTP. Muestra el ancho de banda real del canal."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mesure les débits descendant et montant via des serveurs iperf3 ou HTTP. Affiche le débit réel de la connexion."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "iperf3 सर्वर या HTTP के माध्यम से डाउनलोड और अपलोड गति मापता है। चैनल की वास्तविक बैंडविड्थ दिखाता है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Misura la velocità di download e upload tramite server iperf3 o HTTP. Mostra la reale ampiezza di banda del collegamento."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "iperf3 サーバーまたは HTTP を通じてダウンロード/アップロード速度を測定します。回線の実際のスループットを表示します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "iperf3 서버 또는 HTTP를 통해 다운로드 및 업로드 속도를 측정합니다. 회선의 실제 처리량을 보여줍니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Mede a velocidade de download e upload por servidores iperf3 ou HTTP. Mostra a largura de banda real do canal."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "iperf3 sunucuları veya HTTP üzerinden indirme ve yükleme hızını ölçer. Kanalın gerçek bant genişliğini gösterir."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "通过 iperf3 服务器或 HTTP 测量下载和上传速度。显示链路的真实带宽。"
          }
        }
      }
    },
