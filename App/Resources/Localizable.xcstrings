    "Возвращает истину, если хост отвечает на ping.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يُعيد صحيحاً إذا استجاب المضيف لـ ping."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gibt wahr zurück, wenn der Host auf Ping antwortet."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Returns true if the host responds to ping."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Devuelve verdadero si el host responde al ping."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Renvoie vrai si l'hôte répond au ping."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यदि होस्ट ping का उत्तर देता है तो सत्य लौटाता है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Restituisce vero se l'host risponde al ping."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ホストが ping に応答する場合に真を返します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "호스트가 ping에 응답하면 참을 반환합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Retorna verdadeiro se o host responder ao ping."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sunucu ping'e yanıt verirse doğru döndürür."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "如果主机响应 ping，则返回真。"
          }
        }
      }
    },
