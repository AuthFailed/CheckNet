            "value": "QR कोड स्कैन करने के लिए iOS सेटिंग्ज़ में कैमरे की अनुमति दें।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Consenti l’accesso alla fotocamera nelle Impostazioni di iOS per scansionare i codici QR."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "QRコードを読み取るには、iOS の「設定」でカメラへのアクセスを許可してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "QR 코드를 스캔하려면 iOS 설정에서 카메라 접근을 허용하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Permita o acesso à câmera nos Ajustes do iOS para escanear códigos QR."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "QR kodlarını taramak için iOS Ayarlar’da kamera erişimine izin verin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请在 iOS“设置”中允许访问摄像头，以扫描二维码。"
          }
        }
      }
    },
