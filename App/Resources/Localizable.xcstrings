    "Найдём устройства в вашей сети с IP, MAC и вендором.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We'll find devices on your network with IP, MAC, and vendor."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "查找网络中的设备，含 IP、MAC 与厂商。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Encontraremos los dispositivos de tu red con su IP, MAC y fabricante."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Trouvons les appareils de votre réseau avec leur IP, MAC et fabricant."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wir finden Geräte in Ihrem Netzwerk mit IP, MAC und Hersteller."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ネットワーク内のデバイスを IP・MAC・ベンダーとともに見つけます。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Vamos encontrar os dispositivos na sua rede com IP, MAC e fabricante."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "IP, MAC, 제조사 정보와 함께 네트워크의 기기를 찾습니다."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Troviamo i dispositivi nella tua rete con IP, MAC e produttore."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ağınızdaki cihazları IP, MAC ve üretici bilgisiyle bulalım."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سنعثر على الأجهزة في شبكتك مع IP وMAC والمُصنّع."
          }
