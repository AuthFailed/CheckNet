    "По умолчанию отправляются все данные, которые умеет отдавать инструмент. Здесь можно отключить ненужные поля.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تُرسَل افتراضيًا كل البيانات التي تستطيع الأداة تقديمها. ويمكنك إيقاف الحقول غير المطلوبة من هنا."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Standardmäßig werden alle Daten gesendet, die ein Tool liefern kann. Hier kannst du nicht benötigte Felder deaktivieren."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "By default, every field a tool can report is sent. Here you can turn off the ones you don’t need."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "De forma predeterminada se envían todos los datos que la herramienta puede proporcionar. Aquí puedes desactivar los campos que no necesites."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Par défaut, toutes les données que l’outil sait fournir sont envoyées. Vous pouvez désactiver ici les champs inutiles."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "डिफ़ॉल्ट रूप से वह सारा डेटा भेजा जाता है जो टूल दे सकता है। यहाँ अनावश्यक फ़ील्ड बंद किए जा सकते हैं।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Per impostazione predefinita vengono inviati tutti i dati che lo strumento è in grado di fornire. Qui puoi disattivare i campi non necessari."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "デフォルトでは、ツールが出力できるすべてのデータが送信されます。不要な項目はここでオフにできます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기본적으로 도구가 제공할 수 있는 모든 데이터가 전송돼요. 필요 없는 항목은 여기서 끌 수 있어요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Por padrão são enviados todos os dados que a ferramenta consegue fornecer. Aqui você pode desativar os campos desnecessários."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Varsayılan olarak aracın verebildiği tüm veriler gönderilir. Gereksiz alanları buradan kapatabilirsiniz."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "默认会发送该工具能提供的全部数据。可在此关闭不需要的字段。"
          }
        }
      }
    },
