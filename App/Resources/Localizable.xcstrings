    "Трассировка и пинг одновременно: потери и задержка по каждому хопу, раунд за раундом.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تتبّع واختبار ping معًا: الفقد وزمن الاستجابة لكل قفزة، جولة بعد جولة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Trace und Ping zugleich: Verlust und Latenz pro Hop, Runde für Runde."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Trace and ping at once: loss and latency per hop, round after round."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Traza y ping a la vez: pérdida y latencia por salto, ronda tras ronda."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Trace et ping à la fois : perte et latence par saut, tour après tour."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "ट्रेस और पिंग एक साथ: हर हॉप पर हानि और देरी, हर राउंड में।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Trace e ping insieme: perdita e latenza per hop, giro dopo giro."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "トレースと ping を同時に実行し、ホップごとの損失と遅延をラウンドごとに集計します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "경로 추적과 핑을 동시에 실행해 홉별 손실과 지연을 라운드마다 누적합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Traceroute e ping ao mesmo tempo: perda e latência por salto, rodada após rodada."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aynı anda izleme ve ping: her sekme için kayıp ve gecikme, tur tur."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "同时执行路由跟踪与 ping：逐轮统计每一跳的丢包与延迟。"
          }
        }
      }
    },
