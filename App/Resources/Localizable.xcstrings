    "Читает имя текущей Wi-Fi-сети и запускает профиль для неё. Для чтения имени сети нужны Wi-Fi-права приложения и разрешение на геопозицию (требование iOS).": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يقرأ اسم شبكة Wi-Fi الحالية ويشغّل ملف التعريف الخاص بها. وتتطلب قراءة اسم الشبكة صلاحية Wi-Fi للتطبيق وإذن الموقع (وهو شرط من iOS)."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Liest den Namen des aktuellen Wi-Fi-Netzwerks und startet das passende Profil. Zum Lesen des Netzwerknamens sind die Wi-Fi-Berechtigung der App und die Ortungsfreigabe erforderlich (Vorgabe von iOS)."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reads the name of the current Wi-Fi network and runs the profile for it. Reading the network name requires the app’s Wi-Fi entitlement and location permission (an iOS requirement)."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Lee el nombre de la red Wi-Fi actual y ejecuta el perfil correspondiente. Para leer el nombre de la red hacen falta los permisos de Wi-Fi de la app y el acceso a la ubicación (requisito de iOS)."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lit le nom du réseau Wi-Fi actuel et applique le profil correspondant. La lecture du nom du réseau exige les droits Wi-Fi de l’app et l’autorisation de localisation (exigence d’iOS)."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "मौजूदा Wi-Fi नेटवर्क का नाम पढ़कर उसकी प्रोफ़ाइल चालू करता है। नाम पढ़ने के लिए ऐप को Wi-Fi अधिकार और लोकेशन की अनुमति चाहिए (iOS की शर्त)।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Legge il nome della rete Wi-Fi attuale e avvia il profilo corrispondente. Per leggere il nome della rete servono i diritti Wi-Fi dell’app e l’autorizzazione alla posizione (requisito di iOS)."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "現在の Wi-Fi ネットワーク名を読み取り、それに対応するプロファイルを適用します。ネットワーク名の読み取りには App の Wi-Fi 権限と位置情報の許可が必要です（iOS の要件）。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "현재 Wi-Fi 네트워크 이름을 읽고 그에 맞는 프로파일을 실행해요. 네트워크 이름을 읽으려면 앱의 Wi-Fi 권한과 위치 접근 허용이 필요해요(iOS 요구 사항)."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Lê o nome da rede Wi-Fi atual e ativa o perfil correspondente. Para ler o nome da rede são necessários os direitos de Wi-Fi do app e a permissão de localização (exigência do iOS)."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Geçerli Wi-Fi ağının adını okur ve o ağa ait profili başlatır. Ağ adını okumak için uygulamanın Wi-Fi yetkisi ve konum izni gerekir (iOS gereksinimi)."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "读取当前 Wi-Fi 网络名称并启用对应配置。读取网络名称需要 App 的 Wi-Fi 权限和定位权限（iOS 的要求）。"
          }
        }
      }
    },
    "Что именно недоступно — по провайдерам, сервисам и серверам уведомлений.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ما الذي يتعذّر الوصول إليه بالضبط — بحسب المزوّدين والخدمات وخوادم الإشعارات."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Was genau nicht erreichbar ist – nach Anbietern, Diensten und Mitteilungsservern."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "What exactly is unreachable — by provider, service and notification server."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Qué es exactamente lo que no está accesible: por operadores, servicios y servidores de notificaciones."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce qui est précisément inaccessible — par opérateurs, services et serveurs de notifications."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "क्या-क्या अनुपलब्ध है — प्रोवाइडर, सेवाओं और नोटिफ़िकेशन सर्वर के हिसाब से।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Che cosa non è raggiungibile: per provider, servizi e server di notifiche."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "プロバイダ、サービス、通知サーバーごとに、何に到達できないかを示します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "통신사, 서비스, 알림 서버별로 무엇에 연결할 수 없는지 보여줘요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O que está inacessível: por provedores, serviços e servidores de notificações."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tam olarak neye erişilemiyor — sağlayıcılara, servislere ve bildirim sunucularına göre."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "具体哪些不可访问：按服务商、服务和通知服务器划分。"
          }
        }
      }
    },
