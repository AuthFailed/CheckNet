    "В прогоне не было зарубежных целей, сравнивать не с чем.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لم تتضمّن هذه الجولة أهدافًا خارجية، فلا شيء للمقارنة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Durchlauf enthielt keine Ziele im Ausland, es gibt nichts zu vergleichen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The run had no targets abroad, so there is nothing to compare."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "En esta ejecución no hubo objetivos extranjeros, no hay con qué comparar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucune cible étrangère dans cette exécution, rien à comparer."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इस रन में कोई विदेशी लक्ष्य नहीं था, तुलना करने के लिए कुछ नहीं है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'esecuzione non conteneva destinazioni estere: non c'è nulla da confrontare."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "今回の実行に海外の対象が含まれていないため、比較できません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이번 실행에 해외 대상이 없어 비교할 수 없어요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A execução não incluiu destinos estrangeiros: não há com o que comparar."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu çalıştırmada yurt dışı hedef yoktu, karşılaştıracak bir şey yok."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "本次运行中没有境外目标，无从比较。"
          }
        }
      }
    },
    "В этом QR-коде нет списка хостов CheckNet.": {
      "extractionState": "manual",
