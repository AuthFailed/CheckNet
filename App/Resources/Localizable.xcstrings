      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "حتى العنوان المرجعي غير متاح — تحقّق من الاتصال."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
