    "Добавьте домены или IP-адреса, чтобы поделиться ими.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أضف نطاقات أو عناوين IP لمشاركتها."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Füge Domains oder IP-Adressen hinzu, um sie zu teilen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add domains or IP addresses to share them."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Añade dominios o direcciones IP para compartirlos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoutez des domaines ou des adresses IP pour les partager."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "साझा करने के लिए डोमेन या IP पते जोड़ें।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Aggiungi domini o indirizzi IP per condividerli."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "共有するドメインまたは IP アドレスを追加してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "공유할 도메인이나 IP 주소를 추가하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Adicione domínios ou endereços IP para compartilhá-los."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Paylaşmak için alan adı veya IP adresi ekleyin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "添加域名或 IP 地址后即可分享。"
          }
        }
      }
    },
    "Добавьте хосты для непрерывного мониторинга и уведомлений о падении.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أضِف مضيفين للمراقبة المستمرة والإشعارات عند التعطّل."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fügen Sie Hosts hinzu, um sie kontinuierlich zu überwachen und bei Ausfällen benachrichtigt zu werden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add hosts for continuous monitoring and downtime alerts."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Añade hosts para monitorizarlos de forma continua y recibir avisos de caída."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoutez des hôtes pour une surveillance continue et des notifications de panne."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "निरंतर निगरानी और डाउनटाइम सूचनाओं के लिए होस्ट जोड़ें।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Aggiungi host per il monitoraggio continuo e le notifiche di inattività."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "継続的な監視とダウン通知のためにホストを追加してください。"
          }
        },
