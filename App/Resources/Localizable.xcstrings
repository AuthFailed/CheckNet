    "Тест будет запускаться сам, пока приложение открыто, и попадать в историю автозапусков. Не зависит от вебхуков.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سيعمل الاختبار تلقائيًا ما دام التطبيق مفتوحًا، وستُسجَّل نتائجه في سجل التشغيل التلقائي. وهو مستقل عن Webhooks."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Test läuft automatisch, solange die App geöffnet ist, und erscheint im Verlauf automatischer Starts. Unabhängig von Webhooks."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The test runs on its own while the app is open and lands in the scheduled run history. Independent of webhooks."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La prueba se ejecutará sola mientras la app esté abierta y quedará en el historial de ejecuciones automáticas. No depende de los webhooks."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le test se lancera tout seul tant que l’app est ouverte et sera consigné dans l’historique des lancements auto. Indépendant des webhooks."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "जब तक ऐप खुला है, टेस्ट खुद चलेगा और स्वतः-रन इतिहास में दर्ज होगा। यह वेबहुक पर निर्भर नहीं है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il test verrà eseguito da solo finché l’app è aperta e finirà nella cronologia delle esecuzioni automatiche. Non dipende dai webhook."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "App を開いている間、テストは自動で実行され、自動実行の履歴に記録されます。Webhook とは関係なく動作します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "앱이 열려 있는 동안 테스트가 자동으로 실행되고 자동 실행 기록에 남아요. 웹훅과는 무관하게 동작해요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O teste será executado sozinho enquanto o app estiver aberto e entrará no histórico de execuções automáticas. Não depende dos webhooks."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Test, uygulama açıkken kendiliğinden çalışır ve otomatik çalıştırma geçmişine kaydedilir. Webhook’lardan bağımsızdır."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "只要 App 处于打开状态，测试就会自动运行，并记入自动运行记录。与 Webhook 无关。"
          }
        }
      }
    },
