    "Пройдём по диапазону и покажем, какие адреса отвечают, с именем и задержкой.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سنمسح النطاق ونعرض العناوين المستجيبة مع الاسم وزمن الاستجابة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Geht den Bereich durch und zeigt, welche Adressen antworten – mit Name und Latenz."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We'll walk the range and show which addresses answer, with name and latency."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Recorreremos el rango y mostraremos qué direcciones responden, con nombre y latencia."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nous parcourrons la plage et montrerons quelles adresses répondent, avec nom et latence."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "हम रेंज में जाँच कर बताएंगे कि कौन-से पते उत्तर देते हैं, नाम और देरी के साथ।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Percorreremo l'intervallo e mostreremo quali indirizzi rispondono, con nome e latenza."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "範囲を走査し、応答したアドレスを名前と遅延つきで表示します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "범위를 훑어 응답한 주소를 이름과 지연 시간과 함께 보여줍니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Vamos percorrer a faixa e mostrar quais endereços respondem, com nome e latência."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aralığı tarar ve hangi adreslerin yanıt verdiğini adı ve gecikmesiyle gösteririz."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "遍历该范围，列出有响应的地址及其名称与延迟。"
          }
        }
      }
    },
