    "Стандартный домашний NAT: приватный локальный адрес за одним маршрутизатором.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Standard home NAT: a private local address behind a single router."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "标准家用 NAT：位于单个路由器之后的私有本地地址。"
          }
