    "Преобразует доменное имя в IP-адрес (и наоборот). Простейшая проверка работы DNS.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يحوّل اسم النطاق إلى عنوان IP (والعكس). أبسط فحص لعمل DNS."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wandelt einen Domainnamen in eine IP-Adresse um (und umgekehrt). Die einfachste Prüfung der DNS-Funktion."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Converts a domain name to an IP address (and vice versa). The simplest DNS check."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Convierte un nombre de dominio en una dirección IP (y viceversa). La comprobación más básica del funcionamiento del DNS."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Convertit un nom de domaine en adresse IP (et inversement). La vérification la plus simple du fonctionnement du DNS."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "डोमेन नाम को IP पते में (और उल्टा) बदलता है। DNS के काम करने की सबसे सरल जाँच।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Converte un nome di dominio in un indirizzo IP (e viceversa). Il controllo più semplice del funzionamento del DNS."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ドメイン名を IP アドレスに変換します（またはその逆）。DNS が機能しているかの最も基本的な確認です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "도메인 이름을 IP 주소로 (또는 그 반대로) 변환합니다. DNS 작동에 대한 가장 기본적인 확인입니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Converte um nome de domínio em endereço IP (e vice-versa). A verificação mais simples do funcionamento do DNS."
          }
