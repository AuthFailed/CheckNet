            "value": "Local network access not granted — allow it in iOS Settings."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "本地网络访问未获授权 — 请在 iOS 设置中允许。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El acceso a la red local no está confirmado: permítelo en los Ajustes de iOS."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'accès au réseau local n'est pas confirmé — autorisez-le dans les Réglages d'iOS."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zugriff auf das lokale Netzwerk nicht bestätigt – erlauben Sie ihn in den iOS-Einstellungen."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ローカルネットワークへのアクセスが確認できません — iOS の設定で許可してください。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O acesso à rede local não foi confirmado — autorize-o nos Ajustes do iOS."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "로컬 네트워크 접근이 확인되지 않았습니다 — iOS 설정에서 허용하세요."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
