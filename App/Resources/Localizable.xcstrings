    "Сеть перенаправляет запросы — вероятно, нужен вход через страницу авторизации.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الشبكة تعيد توجيه الطلبات — على الأرجح يلزم تسجيل الدخول عبر صفحة مصادقة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Netzwerk leitet Anfragen um – wahrscheinlich ist eine Anmeldung über eine Login-Seite nötig."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The network redirects requests — a sign-in page is probably required."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La red redirige las solicitudes: probablemente haya que iniciar sesión en una página de autenticación."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le réseau redirige les requêtes — une connexion via une page d’authentification est probablement nécessaire."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "नेटवर्क अनुरोध रीडायरेक्ट कर रहा है — शायद लॉगिन पेज से साइन इन करना ज़रूरी है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La rete reindirizza le richieste: probabilmente serve l'accesso tramite una pagina di autenticazione."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ネットワークがリクエストをリダイレクトしています。認証ページからのサインインが必要と考えられます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "네트워크가 요청을 리디렉션하고 있어요. 인증 페이지에서 로그인해야 할 수 있어요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A rede redireciona as solicitações: provavelmente é necessário fazer login por uma página de autenticação."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ağ istekleri yönlendiriyor — muhtemelen bir oturum açma sayfasından giriş yapmak gerekiyor."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "网络会重定向请求，可能需要通过认证页面登录。"
          }
        }
      }
    },
