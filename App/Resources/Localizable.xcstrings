    "Проверки сравнивают ваше соединение с эталоном и показывают, что именно ограничивает сеть.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تقارن الفحوصات اتصالك بمرجع وتُظهر ما الذي تقيّده الشبكة بالضبط."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Prüfungen vergleichen deine Verbindung mit einer Referenz und zeigen, was das Netzwerk genau einschränkt."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The checks compare your connection with a reference and show exactly what the network restricts."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las comprobaciones comparan tu conexión con una de referencia y muestran qué restringe exactamente la red."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les vérifications comparent votre connexion à une référence et montrent ce que le réseau restreint exactement."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "जाँच आपके कनेक्शन की तुलना संदर्भ से करती है और दिखाती है कि नेटवर्क वास्तव में क्या सीमित करता है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I controlli confrontano la tua connessione con un riferimento e mostrano che cosa limita esattamente la rete."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "チェックでは、お使いの接続を対照と比較し、ネットワークが何を制限しているかを示します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "검사는 사용자의 연결을 대조와 비교해 네트워크가 무엇을 제한하는지 보여줘요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "As verificações comparam sua conexão com uma referência e mostram o que exatamente a rede limita."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Testler bağlantınızı bir referansla karşılaştırır ve ağın tam olarak neyi kısıtladığını gösterir."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "检查会将你的连接与参照进行比较，并显示网络具体限制了什么。"
          }
        }
      }
    },
