    "Wake-on-LAN работает только в локальной сети и требует, чтобы устройство поддерживало пробуждение по сети.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يعمل Wake-on-LAN داخل الشبكة المحلية فقط ويتطلب أن يدعم الجهاز الإيقاظ عبر الشبكة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wake-on-LAN funktioniert nur im lokalen Netzwerk und setzt voraus, dass das Gerät das Aufwecken über das Netzwerk unterstützt."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Wake-on-LAN works only on the local network and requires the device to support wake-on-network."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Wake-on-LAN solo funciona en la red local y requiere que el dispositivo admita el encendido por red."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le Wake-on-LAN ne fonctionne que sur le réseau local et nécessite que l'appareil prenne en charge le réveil par le réseau."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Wake-on-LAN केवल स्थानीय नेटवर्क में काम करता है और इसके लिए डिवाइस को नेटवर्क द्वारा जगाने का समर्थन करना आवश्यक है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Wake-on-LAN funziona solo nella rete locale e richiede che il dispositivo supporti la riattivazione via rete."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Wake-on-LAN はローカルネットワーク内でのみ動作し、デバイスがネットワーク経由の起動に対応している必要があります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Wake-on-LAN은 로컬 네트워크에서만 작동하며 기기가 네트워크 깨우기를 지원해야 합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Wake-on-LAN funciona apenas na rede local e exige que o dispositivo tenha suporte a despertar pela rede."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Wake-on-LAN yalnızca yerel ağda çalışır ve cihazın ağ üzerinden uyandırmayı desteklemesini gerektirir."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Wake-on-LAN 仅在局域网内有效，并要求设备支持网络唤醒。"
          }
        }
      }
    },
