    "Спрашивает один и тот же домен у нескольких DNS-резолверов и сравнивает ответы бок о бок. Помогает заметить подмену или расхождения.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يستعلم عن النطاق نفسه من عدة محلّلات DNS ويقارن الاستجابات جنباً إلى جنب. يساعد على ملاحظة التزوير أو الاختلافات."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fragt dieselbe Domain bei mehreren DNS-Resolvern ab und vergleicht die Antworten nebeneinander. Hilft, Fälschungen oder Abweichungen zu erkennen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Queries the same domain from several DNS resolvers and compares the responses side by side. Helps spot spoofing or discrepancies."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Consulta el mismo dominio a varios resolutores DNS y compara las respuestas en paralelo. Ayuda a detectar falsificaciones o discrepancias."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Interroge le même domaine auprès de plusieurs résolveurs DNS et compare les réponses côte à côte. Aide à repérer une falsification ou des divergences."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "एक ही डोमेन को कई DNS रिज़ॉल्वरों से पूछता है और उत्तरों की साथ-साथ तुलना करता है। छेड़छाड़ या भिन्नता देखने में मदद करता है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Interroga lo stesso dominio su più resolver DNS e confronta le risposte una accanto all'altra. Aiuta a notare alterazioni o discrepanze."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "同じドメインを複数の DNS リゾルバに問い合わせ、応答を並べて比較します。改ざんや不一致に気づくのに役立ちます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "여러 DNS 리졸버에 동일한 도메인을 조회하고 응답을 나란히 비교합니다. 변조나 불일치를 발견하는 데 유용합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Consulta o mesmo domínio em vários resolvedores DNS e compara as respostas lado a lado. Ajuda a notar adulteração ou divergências."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aynı alan adını birden fazla DNS çözümleyicisine sorar ve yanıtları yan yana karşılaştırır. Sahtekârlığı veya tutarsızlıkları fark etmeye yardımcı olur."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "向多个 DNS 解析器查询同一域名并并排对比响应。帮助发现篡改或差异。"
          }
        }
      }
    },
    "Спросим выбранный резолвер о записях домена и покажем ответ целиком.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سنسأل المحلّل المختار عن سجلات النطاق ونعرض الإجابة كاملة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fragt den gewählten Resolver nach den Einträgen der Domain und zeigt die vollständige Antwort."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We'll ask the chosen resolver for the domain's records and show the whole answer."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Preguntaremos al resolutor elegido por los registros del dominio y mostraremos la respuesta completa."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nous demanderons au résolveur choisi les enregistrements du domaine et afficherons la réponse entière."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "चुने गए रिज़ॉल्वर से डोमेन के रिकॉर्ड पूछेंगे और पूरा उत्तर दिखाएंगे।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Chiederemo al resolver scelto i record del dominio e mostreremo l'intera risposta."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "選んだリゾルバーにドメインのレコードを問い合わせ、応答全体を表示します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "선택한 리졸버에 도메인 레코드를 질의하고 응답 전체를 보여줍니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Vamos perguntar ao resolvedor escolhido pelos registros do domínio e mostrar a resposta inteira."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Seçili çözümleyiciye alan adının kayıtlarını sorar ve yanıtın tamamını gösteririz."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "向所选解析器查询该域名的记录，并展示完整应答。"
          }
        }
      }
    },
    "Спросим один домен у нескольких публичных резолверов сразу — расхождение в ответах видно построчно.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سنسأل عدة محلّلات عامة عن النطاق نفسه في آنٍ واحد، ويظهر الاختلاف سطرًا بسطر."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fragt mehrere öffentliche Resolver gleichzeitig nach einer Domain – Abweichungen sind zeilenweise sichtbar."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We'll ask several public resolvers about one domain at once — a disagreement shows up line by line."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Preguntaremos por un dominio a varios resolutores públicos a la vez: las discrepancias se ven línea por línea."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nous interrogerons plusieurs résolveurs publics sur un même domaine : les divergences apparaissent ligne par ligne."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "एक ही डोमेन को कई सार्वजनिक रिज़ॉल्वर से एक साथ पूछेंगे — अंतर पंक्ति-दर-पंक्ति दिखता है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Chiederemo lo stesso dominio a più resolver pubblici insieme: le divergenze si vedono riga per riga."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "同じドメインを複数の公開リゾルバーへ同時に問い合わせ、応答の食い違いを行ごとに示します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "같은 도메인을 여러 공개 리졸버에 동시에 질의해 응답 차이를 줄 단위로 보여줍니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Vamos perguntar sobre um domínio a vários resolvedores públicos ao mesmo tempo — as divergências aparecem linha a linha."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aynı alan adını birkaç genel çözümleyiciye aynı anda sorarız; yanıt farkları satır satır görünür."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "同时向多个公共解析器查询同一域名——差异逐行呈现。"
          }
        }
      }
    },
