    "По IP-адресу находит связанное с ним доменное имя (PTR-запись). Помогает опознать владельца адреса.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يعثر على اسم النطاق المرتبط بعنوان IP (سجل PTR). يساعد على التعرف على مالك العنوان."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Findet zu einer IP-Adresse den zugehörigen Domainnamen (PTR-Eintrag). Hilft, den Inhaber der Adresse zu identifizieren."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Finds the domain name associated with an IP address (PTR record). Helps identify the address owner."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "A partir de una dirección IP encuentra el nombre de dominio asociado (registro PTR). Ayuda a identificar al propietario de la dirección."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Trouve le nom de domaine associé à une adresse IP (enregistrement PTR). Aide à identifier le propriétaire de l'adresse."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "IP पते से उससे जुड़ा डोमेन नाम (PTR रिकॉर्ड) ढूँढता है। पते के मालिक की पहचान में मदद करता है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "A partire da un indirizzo IP trova il nome di dominio associato (record PTR). Aiuta a identificare il proprietario dell'indirizzo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "IP アドレスから関連するドメイン名（PTR レコード）を検出します。アドレスの所有者を特定するのに役立ちます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "IP 주소로 연결된 도메인 이름(PTR 레코드)을 찾습니다. 주소 소유자를 식별하는 데 유용합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A partir de um endereço IP, encontra o nome de domínio associado a ele (registro PTR). Ajuda a identificar o dono do endereço."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bir IP adresine bağlı alan adını (PTR kaydı) bulur. Adresin sahibini tanımlamaya yardımcı olur."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "根据 IP 地址查找与之关联的域名（PTR 记录）。帮助识别地址的归属方。"
          }
        }
      }
    },
    "По провайдерам": {
      "extractionState": "manual",
      "localizations": {
