    "Оператор использует Carrier-Grade NAT — входящие подключения и проброс портов недоступны.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يستخدم المشغّل Carrier-Grade NAT — الاتصالات الواردة وإعادة توجيه المنافذ غير متاحة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Anbieter verwendet Carrier-Grade NAT – eingehende Verbindungen und Portweiterleitung sind nicht möglich."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The carrier uses Carrier-Grade NAT — incoming connections and port forwarding are unavailable."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El operador usa Carrier-Grade NAT: las conexiones entrantes y el reenvío de puertos no están disponibles."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'opérateur utilise un Carrier-Grade NAT — les connexions entrantes et la redirection de ports sont indisponibles."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "ऑपरेटर Carrier-Grade NAT का उपयोग करता है — इनकमिंग कनेक्शन और पोर्ट फ़ॉरवर्डिंग उपलब्ध नहीं हैं।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'operatore usa il Carrier-Grade NAT — le connessioni in entrata e l'inoltro delle porte non sono disponibili."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "通信事業者が Carrier-Grade NAT を使用しています — 着信接続とポート転送は利用できません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "통신사가 Carrier-Grade NAT를 사용합니다 — 인바운드 연결과 포트 포워딩을 사용할 수 없습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A operadora usa Carrier-Grade NAT — conexões de entrada e redirecionamento de portas não estão disponíveis."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Operatör Carrier-Grade NAT kullanıyor — gelen bağlantılar ve port yönlendirme kullanılamaz."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "运营商使用运营商级 NAT — 无法进行入站连接和端口转发。"
          }
        }
      }
    },
    "Определение сети доступно только на iOS.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تحديد الشبكة متاح على iOS فقط."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Netzwerkerkennung ist nur unter iOS verfügbar."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Network detection is available on iOS only."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La detección de la red solo está disponible en iOS."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La détection du réseau n’est disponible que sur iOS."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "नेटवर्क की पहचान केवल iOS पर उपलब्ध है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il rilevamento della rete è disponibile solo su iOS."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ネットワークの判別は iOS でのみ利用できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "네트워크 확인은 iOS에서만 사용할 수 있어요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A detecção da rede está disponível apenas no iOS."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ağ algılama yalnızca iOS’ta kullanılabilir."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "网络识别仅在 iOS 上可用。"
          }
        }
      }
    },
