    "Сохранённые адреса появляются в меню закладок на каждом экране с полем ввода.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تظهر العناوين المحفوظة في قائمة الإشارات المرجعية على كل شاشة فيها حقل إدخال."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gespeicherte Adressen erscheinen im Lesezeichenmenü auf jedem Bildschirm mit Eingabefeld."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Saved addresses show up in the bookmarks menu on every screen with an input field."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las direcciones guardadas aparecen en el menú de marcadores de cada pantalla con campo de entrada."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les adresses enregistrées apparaissent dans le menu des signets sur chaque écran doté d'un champ de saisie."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सहेजे गए पते हर उस स्क्रीन के बुकमार्क मेनू में दिखते हैं जिसमें इनपुट फ़ील्ड है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Gli indirizzi salvati compaiono nel menu dei segnalibri in ogni schermata con un campo di inserimento."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "保存したアドレスは、入力欄のある各画面のブックマークメニューに表示されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "저장한 주소는 입력란이 있는 모든 화면의 북마크 메뉴에 나타납니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Os endereços salvos aparecem no menu de favoritos em cada tela com campo de entrada."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kaydedilen adresler, giriş alanı olan her ekrandaki yer imleri menüsünde görünür."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已保存的地址会出现在每个带输入框页面的书签菜单中。"
          }
        }
      }
    },
