    "Apple APNs и Google FCM отвечают — сеть доставку уведомлений не блокирует.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يستجيب كل من Apple APNs وGoogle FCM — الشبكة لا تحجب تسليم الإشعارات."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple APNs und Google FCM antworten – das Netzwerk blockiert die Zustellung von Mitteilungen nicht."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple APNs and Google FCM respond — the network is not blocking notification delivery."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple APNs y Google FCM responden: la red no bloquea la entrega de notificaciones."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple APNs et Google FCM répondent — le réseau ne bloque pas la distribution des notifications."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple APNs और Google FCM जवाब दे रहे हैं — नेटवर्क नोटिफ़िकेशन की डिलीवरी नहीं रोक रहा।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple APNs e Google FCM rispondono: la rete non blocca la consegna delle notifiche."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple APNs と Google FCM が応答しています。ネットワークは通知の配信を制限していません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple APNs와 Google FCM이 응답해요. 네트워크가 알림 전달을 차단하지 않아요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple APNs e Google FCM respondem: a rede não bloqueia a entrega de notificações."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple APNs ve Google FCM yanıt veriyor — ağ bildirim teslimini engellemiyor."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple APNs 和 Google FCM 均有响应，网络未阻止通知送达。"
          }
        }
      }
    },
