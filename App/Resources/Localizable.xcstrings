    "Зарубежные ресурсы доступны наравне с локальными.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الموارد الأجنبية متاحة كالمحلية تماماً."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ausländische Ressourcen sind genauso verfügbar wie lokale."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Foreign resources are as reachable as local ones."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los recursos extranjeros están disponibles igual que los locales."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les ressources étrangères sont accessibles au même titre que les locales."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "विदेशी संसाधन स्थानीय संसाधनों के बराबर उपलब्ध हैं।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le risorse estere sono disponibili come quelle locali."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "海外リソースもローカルと同様に利用可能です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "해외 리소스가 국내 리소스와 동일하게 접속됩니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Os recursos estrangeiros estão acessíveis do mesmo modo que os locais."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yurt dışı kaynaklar, yerel kaynaklarla eşit şekilde erişilebilir."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "境外资源与本地资源同样可访问。"
          }
        }
      }
    },
