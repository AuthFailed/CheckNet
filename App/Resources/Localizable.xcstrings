    "%@ вернул приватный адрес %@ для публичного хоста.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ returned a private address %@ for a public host."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 为公共主机返回了私有地址 %@。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ devolvió la dirección privada %@ para un host público."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ a renvoyé une adresse privée %@ pour un hôte public."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ hat für einen öffentlichen Host die private Adresse %@ zurückgegeben."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ が公開ホストに対してプライベートアドレス %@ を返しました。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ retornou o endereço privado %@ para um host público."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@이(가) 공개 호스트에 대해 사설 주소 %@을(를) 반환했습니다."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ ha restituito un indirizzo privato %@ per un host pubblico."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@, genel bir sunucu için özel adres %@ döndürdü."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ أعاد عنواناً خاصاً %@ لمضيف عام."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ ने सार्वजनिक होस्ट के लिए निजी पता %@ लौटाया।"
          }
        }
      }
    },
