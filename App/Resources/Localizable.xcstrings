    "Покажем каждый маршрутизатор на пути до хоста и задержку на каждом шаге.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سنعرض كل موجّه على المسار إلى المضيف وزمن الاستجابة عند كل خطوة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zeigt jeden Router auf dem Weg zum Host und die Latenz bei jedem Schritt."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We'll show every router on the way to the host and the latency at each step."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mostraremos cada router en el camino al host y la latencia en cada salto."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nous montrerons chaque routeur sur le chemin vers l'hôte et la latence à chaque étape."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "हम होस्ट तक के रास्ते का हर राउटर और हर चरण की देरी दिखाएंगे।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Mostreremo ogni router sul percorso verso l'host e la latenza a ogni passo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ホストまでの各ルーターと、その各段階の遅延を表示します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "호스트까지 거치는 각 라우터와 단계별 지연 시간을 보여줍니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Mostraremos cada roteador no caminho até o host e a latência em cada etapa."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ana bilgisayara giden yoldaki her yönlendiriciyi ve her adımdaki gecikmeyi gösterir."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "显示通往主机路径上的每一跳路由及其延迟。"
          }
        }
      }
    },
    "Покажем цепочку сертификатов, сроки действия, версию TLS и шифр.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سنعرض سلسلة الشهادات ومدد الصلاحية وإصدار TLS والتشفير."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zeigt die Zertifikatskette, Gültigkeitsdaten, TLS-Version und Cipher."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We'll show the certificate chain, validity dates, TLS version and cipher."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mostraremos la cadena de certificados, la validez, la versión de TLS y el cifrado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nous afficherons la chaîne de certificats, les dates de validité, la version TLS et le chiffrement."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "हम प्रमाणपत्र शृंखला, वैधता, TLS संस्करण और सिफर दिखाएंगे।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Mostreremo la catena di certificati, le date di validità, la versione TLS e il cifrario."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "証明書チェーン、有効期限、TLS バージョン、暗号スイートを表示します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "인증서 체인, 유효 기간, TLS 버전, 암호 스위트를 보여줍니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Mostraremos a cadeia de certificados, a validade, a versão do TLS e a cifra."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
