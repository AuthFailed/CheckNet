    "Оба соединения не прошли — вероятно, IP-блокировка или хост недоступен.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لم ينجح كلا الاتصالين — يُرجَّح حجب IP أو أن المضيف غير متاح."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Beide Verbindungen sind nicht durchgekommen – wahrscheinlich eine IP-Sperre oder der Host ist nicht erreichbar."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Both connections failed — likely an IP block or the host is unreachable."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ninguna de las dos conexiones pasó: probablemente un bloqueo por IP o el host no está disponible."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les deux connexions ont échoué — probablement un blocage par IP ou un hôte inaccessible."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "दोनों कनेक्शन विफल रहे — संभवतः IP अवरोध है या होस्ट उपलब्ध नहीं है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Entrambe le connessioni sono fallite — probabilmente un blocco IP o l'host non è raggiungibile."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "両方の接続が成立しませんでした — IP ブロックか、ホストに到達できない可能性があります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "두 연결 모두 통과하지 못했습니다 — IP 차단이거나 호스트에 접속할 수 없을 가능성이 높습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ambas as conexões falharam — provavelmente bloqueio de IP ou o host está inacessível."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Her iki bağlantı da geçmedi — muhtemelen IP engellemesi var ya da sunucu erişilemiyor."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "两个连接均未通过 — 很可能是 IP 封锁，或主机不可访问。"
          }
        }
      }
    },
