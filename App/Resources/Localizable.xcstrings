    "Только диагностика: приложение показывает, какие ограничения применяет сеть, и не помогает их обходить.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "للتشخيص فقط: يعرض التطبيق القيود التي تطبّقها الشبكة ولا يساعد على تجاوزها."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nur Diagnose: Die App zeigt, welche Einschränkungen das Netzwerk anwendet, und hilft nicht dabei, sie zu umgehen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Diagnostics only: the app shows which restrictions the network applies and does not help to bypass them."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Solo diagnóstico: la app muestra qué restricciones aplica la red, pero no ayuda a eludirlas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Diagnostic uniquement : l’app indique les restrictions appliquées par le réseau, sans aider à les contourner."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "केवल डायग्नोस्टिक्स: ऐप दिखाता है कि नेटवर्क कौन-से प्रतिबंध लगाता है, उन्हें बायपास करने में मदद नहीं करता।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Solo diagnostica: l’app mostra quali restrizioni applica la rete e non aiuta ad aggirarle."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "診断のみ：この App はネットワークが適用している制限を表示するだけで、その回避は行いません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "진단 전용이에요. 이 앱은 네트워크가 적용하는 제한을 보여줄 뿐, 우회를 돕지 않아요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Somente diagnóstico: o app mostra quais restrições a rede aplica e não ajuda a contorná-las."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yalnızca tanılama: uygulama ağın hangi kısıtlamaları uyguladığını gösterir, bunları aşmaya yardımcı olmaz."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "仅用于诊断：App 只显示网络施加了哪些限制，不提供绕过手段。"
          }
        }
      }
    },
