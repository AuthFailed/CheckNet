    "Прямое подключение к реальному адресу домена не проходит, хотя контрольный адрес доступен.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A direct connection to the domain's real address doesn't go through, even though the control address is reachable."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法直接连接到域名的真实地址，尽管控制地址可访问。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La conexión directa a la dirección real del dominio no pasa, aunque la dirección de control sí está disponible."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La connexion directe à l'adresse réelle du domaine échoue, bien que l'adresse de contrôle soit accessible."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die direkte Verbindung zur tatsächlichen Adresse der Domain kommt nicht zustande, obwohl die Kontrolladresse erreichbar ist."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "基準アドレスには到達できるのに、ドメインの実際のアドレスへの直接接続は成立しません。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A conexão direta ao endereço real do domínio não passa, embora o endereço de controle esteja acessível."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기준 주소는 접속 가능하지만 도메인의 실제 주소로의 직접 연결은 통과하지 못합니다."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La connessione diretta all'indirizzo reale del dominio non riesce, anche se l'indirizzo di controllo è raggiungibile."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kontrol adresi erişilebilir olmasına rağmen, alan adının gerçek adresine doğrudan bağlantı geçmiyor."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الاتصال المباشر بالعنوان الحقيقي للنطاق لا ينجح رغم توفّر العنوان المرجعي."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "डोमेन के वास्तविक पते से सीधा कनेक्शन नहीं होता, जबकि नियंत्रण पता उपलब्ध है।"
          }
        }
      }
    },
