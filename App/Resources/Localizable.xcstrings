            "value": "डाउनटाइम सूचनाओं का अनुरोध शुरू होने पर किया जाएगा।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le notifiche di inattività verranno richieste all'avvio."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ダウン通知は起動時にリクエストされます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "다운 알림은 시작 시 요청됩니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "As notificações de queda serão solicitadas na inicialização."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kesinti bildirimleri başlatmada istenecek."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "中断通知将在启动时请求授权。"
          }
