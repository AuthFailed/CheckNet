    "Российские узлы при этом отвечают — ограничение зависит от назначения.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أما العُقد الروسية فتستجيب — القيد يعتمد على الوجهة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Russische Hosts antworten dabei – die Einschränkung hängt vom Ziel ab."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Russian hosts do respond — the restriction depends on the destination."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los nodos rusos sí responden: la restricción depende del destino."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les nœuds russes répondent pourtant — la restriction dépend de la destination."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "वहीं रूसी नोड जवाब दे रहे हैं — पाबंदी गंतव्य पर निर्भर करती है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I nodi russi invece rispondono: la limitazione dipende dalla destinazione."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ロシア国内のノードは応答しています。制限は接続先によって異なります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "러시아 국내 노드는 응답해요. 제한은 연결 대상에 따라 달라요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Já os nós russos respondem: a restrição depende do destino."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Rusya’daki sunucular ise yanıt veriyor — kısıtlama hedefe bağlı."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "与此同时俄罗斯节点有响应，限制取决于目标地址。"
          }
        }
      }
    },
    "Российский контроль не затронут — ограничение зависит от назначения.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "التحكّم الروسي غير متأثر — القيد يعتمد على الوجهة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die russische Kontrollverbindung ist nicht betroffen – die Einschränkung hängt vom Ziel ab."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The Russian control is unaffected — the restriction depends on the destination."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El control ruso no se ve afectado: la restricción depende del destino."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le contrôle russe n’est pas affecté — la restriction dépend de la destination."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "रूसी कंट्रोल प्रभावित नहीं है — पाबंदी गंतव्य पर निर्भर करती है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il controllo russo non è interessato: la limitazione dipende dalla destinazione."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ロシア国内の対照は影響を受けていません。制限は接続先によって異なります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "러시아 국내 대조는 영향을 받지 않았어요. 제한은 연결 대상에 따라 달라요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O controle russo não é afetado: a restrição depende do destino."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Rusya’daki kontrol etkilenmedi — kısıtlama hedefe bağlı."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "俄罗斯对照未受影响，限制取决于目标地址。"
          }
        }
      }
    },
