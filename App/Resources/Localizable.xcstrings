    "Слева — все проверки. Выберите любую, чтобы запустить её.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعرض القائمة الجانبية جميع الفحوصات. اختر أيًّا منها لتشغيله."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Links stehen alle Prüfungen. Wähle eine aus, um sie zu starten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "All checks are on the left. Select one to run it."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "A la izquierda están todas las comprobaciones. Selecciona una para ejecutarla."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "À gauche, toutes les vérifications. Choisissez-en une pour la lancer."
