    "Пингует хост и сообщает задержку и потери.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يجري ping للمضيف ويُبلغ عن التأخير والفقد."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Pingt den Host an und meldet Latenz und Verlust."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pings the host and reports latency and loss."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Hace ping al host e informa de la latencia y las pérdidas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ping l'hôte et indique la latence et les pertes."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "होस्ट को ping करता है और विलंब व हानि बताता है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Esegue il ping dell'host e riporta latenza e perdita."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ホストに ping を送信し、遅延と損失を報告します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "호스트에 ping을 보내 지연과 손실을 알려줍니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Faz ping no host e informa a latência e as perdas."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sunucuya ping atar ve gecikme ile kaybı bildirir."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "对主机进行 ping 并报告延迟与丢包。"
          }
        }
      }
    },
