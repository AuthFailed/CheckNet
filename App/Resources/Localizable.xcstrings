    "Узнаем регистратора домена, даты регистрации и окончания, серверы имён.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سنعرف الجهة المسجِّلة وتواريخ التسجيل والانتهاء وخوادم الأسماء."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ermittelt Registrar, Registrierungs- und Ablaufdatum sowie die Nameserver."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We'll look up the registrar, the registration and expiry dates, and the name servers."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Consultaremos el registrador, las fechas de registro y expiración, y los servidores de nombres."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nous chercherons le bureau d'enregistrement, les dates de création et d'expiration et les serveurs de noms."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "हम रजिस्ट्रार, पंजीकरण व समाप्ति तिथियाँ और नेम सर्वर पता करेंगे।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Cercheremo il registrar, le date di registrazione e scadenza e i name server."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "レジストラ、登録日と有効期限、ネームサーバーを調べます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "등록 대행사, 등록일과 만료일, 네임서버를 조회합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Vamos consultar o registrador, as datas de registro e expiração e os servidores de nomes."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Alan adının kayıt şirketini, kayıt ve bitiş tarihlerini, ad sunucularını buluruz."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "查询注册商、注册与到期日期以及域名服务器。"
          }
        }
      }
    },
    "Уровень сигнала Wi-Fi и потери. Ограничено политиками iOS.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "قوة إشارة Wi-Fi والفقد. مقيّد بسياسات iOS."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wi-Fi-Signalstärke und Verlust. Durch iOS-Richtlinien eingeschränkt."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Wi-Fi signal strength and loss. Limited by iOS policies."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Nivel de señal Wi-Fi y pérdidas. Limitado por las políticas de iOS."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Niveau du signal Wi-Fi et pertes. Limité par les règles d'iOS."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Wi-Fi सिग्नल स्तर और हानि। iOS नीतियों द्वारा सीमित।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Intensità del segnale Wi-Fi e perdita. Limitato dalle policy di iOS."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Wi-Fi の信号強度と損失。iOS のポリシーにより制限されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Wi-Fi 신호 강도와 손실. iOS 정책에 의해 제한됩니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Intensidade do sinal de Wi-Fi e perdas. Limitado pelas políticas do iOS."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Wi-Fi sinyal gücü ve kayıp. iOS politikalarıyla sınırlıdır."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Wi-Fi 信号强度与丢包。受 iOS 策略限制。"
          }
        }
      }
    },
