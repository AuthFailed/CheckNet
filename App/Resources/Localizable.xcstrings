    "Не удалось открыть ICMP-сокет: %@. На iOS проверьте разрешение «Локальная сеть».": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعذّر فتح مقبس ICMP: %@. على iOS تحقّق من إذن «الشبكة المحلية»."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "ICMP-Socket konnte nicht geöffnet werden: %@. Prüfen Sie unter iOS die Berechtigung „Lokales Netzwerk“."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Failed to open ICMP socket: %@. On iOS, check the “Local Network” permission."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo abrir el socket ICMP: %@. En iOS, comprueba el permiso “Red local”."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible d'ouvrir le socket ICMP : %@. Sur iOS, vérifiez l'autorisation « Réseau local »."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "ICMP सॉकेट नहीं खोला जा सका: %@। iOS पर “स्थानीय नेटवर्क” अनुमति जाँचें।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossibile aprire il socket ICMP: %@. Su iOS verifica l'autorizzazione “Rete locale”."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ICMP ソケットを開けませんでした：%@。iOS では「ローカルネットワーク」の許可を確認してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "ICMP 소켓을 열 수 없습니다: %@. iOS에서 「로컬 네트워크」 권한을 확인하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
