    "Найдём наибольший пакет, который доходит до хоста без фрагментации.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سنجد أكبر حزمة تصل إلى المضيف دون تجزئة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Findet das größte Paket, das den Host ohne Fragmentierung erreicht."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We'll find the largest packet that reaches the host without fragmentation."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Buscaremos el paquete más grande que llega al host sin fragmentarse."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nous trouverons le plus grand paquet qui atteint l'hôte sans fragmentation."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "हम सबसे बड़ा पैकेट खोजेंगे जो बिना विखंडन के होस्ट तक पहुंचता है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Troveremo il pacchetto più grande che raggiunge l'host senza frammentazione."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "フラグメント化されずにホストへ届く最大パケットを探します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "조각화 없이 호스트에 도달하는 가장 큰 패킷을 찾습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Vamos encontrar o maior pacote que chega ao host sem fragmentação."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Parçalanmadan ana bilgisayara ulaşan en büyük paketi buluruz."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "找出无需分片即可到达主机的最大数据包。"
          }
        }
      }
    },
    "Найдём устройства в вашей сети с IP, MAC и вендором.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سنعثر على الأجهزة في شبكتك مع IP وMAC والمُصنّع."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wir finden Geräte in Ihrem Netzwerk mit IP, MAC und Hersteller."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We'll find devices on your network with IP, MAC, and vendor."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Encontraremos los dispositivos de tu red con su IP, MAC y fabricante."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Trouvons les appareils de votre réseau avec leur IP, MAC et fabricant."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "हम आपके नेटवर्क में IP, MAC और वेंडर सहित डिवाइस खोजेंगे।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Troviamo i dispositivi nella tua rete con IP, MAC e produttore."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ネットワーク内のデバイスを IP・MAC・ベンダーとともに見つけます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "IP, MAC, 제조사 정보와 함께 네트워크의 기기를 찾습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Vamos encontrar os dispositivos na sua rede com IP, MAC e fabricante."
          }
        },
        "tr": {
