    "Отсканируйте QR-код с другого устройства или скопируйте присланную ссылку checknet:// — приложение покажет, что именно будет добавлено.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "امسح رمز QR من جهاز آخر أو انسخ رابط checknet:// المُرسَل، وسيعرض التطبيق ما الذي ستتم إضافته بالضبط."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Scanne einen QR-Code von einem anderen Gerät oder kopiere einen erhaltenen checknet://-Link – die App zeigt dir, was genau hinzugefügt wird."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Scan a QR code from another device or copy a checknet:// link you received — the app will show exactly what gets added."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Escanea el código QR de otro dispositivo o copia el enlace checknet:// que te hayan enviado: la app mostrará qué se va a añadir."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Scannez un code QR depuis un autre appareil ou collez le lien checknet:// reçu — l’app affichera ce qui sera ajouté."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "दूसरे डिवाइस से QR कोड स्कैन करें या भेजा गया checknet:// लिंक कॉपी करें — ऐप दिखाएगा कि वास्तव में क्या जोड़ा जाएगा।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scansiona un codice QR da un altro dispositivo o copia il link checknet:// ricevuto: l’app mostrerà che cosa verrà aggiunto."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "別のデバイスの QRコードを読み取るか、送られてきた checknet:// リンクをコピーしてください。追加される内容が表示されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "다른 기기의 QR 코드를 스캔하거나 받은 checknet:// 링크를 복사하세요. 무엇이 추가되는지 앱에서 보여줘요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Escaneie um código QR de outro dispositivo ou copie o link checknet:// recebido — o app mostrará exatamente o que será adicionado."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Başka bir cihazdaki QR kodunu tarayın veya gönderilen checknet:// bağlantısını kopyalayın; uygulama tam olarak neyin ekleneceğini gösterir."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "扫描另一台设备上的二维码，或拷贝收到的 checknet:// 链接——App 会显示具体将添加哪些内容。"
          }
        }
      }
    },
    "Отсканируйте камерой на другом устройстве с установленным CheckNet.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "امسحه بكاميرا جهاز آخر مثبَّت عليه CheckNet."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Scanne ihn mit der Kamera eines anderen Geräts, auf dem CheckNet installiert ist."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Scan it with the camera on another device that has CheckNet installed."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Escanéalo con la cámara de otro dispositivo que tenga CheckNet instalado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Scannez-le avec l’appareil photo d’un autre appareil où CheckNet est installé."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "CheckNet वाले दूसरे डिवाइस के कैमरे से स्कैन करें।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scansionalo con la fotocamera di un altro dispositivo su cui è installato CheckNet."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "CheckNet がインストールされた別のデバイスのカメラで読み取ってください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "CheckNet이 설치된 다른 기기의 카메라로 스캔하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Escaneie com a câmera de outro dispositivo que tenha o CheckNet instalado."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "CheckNet yüklü başka bir cihazın kamerasıyla tarayın."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "用另一台已安装 CheckNet 的设备扫描。"
          }
        }
      }
    },
