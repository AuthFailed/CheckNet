    "Локальный и внешний адрес совпадают — вы напрямую в интернете.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "العنوان المحلي والخارجي متطابقان — أنت متصل بالإنترنت مباشرة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lokale und externe Adresse stimmen überein – Sie sind direkt mit dem Internet verbunden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Local and external addresses match — you're directly on the internet."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La dirección local y la externa coinciden: estás conectado directamente a internet."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les adresses locale et externe sont identiques — vous êtes directement sur Internet."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "स्थानीय और बाहरी पता समान हैं — आप सीधे इंटरनेट पर हैं।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'indirizzo locale ed esterno coincidono — sei connesso direttamente a internet."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ローカルアドレスと外部アドレスが一致します — インターネットに直接接続されています。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "로컬 주소와 외부 주소가 일치합니다 — 인터넷에 직접 연결되어 있습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O endereço local e o externo coincidem — você está diretamente na internet."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yerel ve dış adres aynı — doğrudan internete bağlısınız."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "本地地址与外网地址一致 — 你直接连接到互联网。"
          }
        }
      }
    },
