    "Доступ к геопозиции запрещён — имя сети iOS не отдаёт.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم رفض الوصول إلى الموقع — لا يوفّر iOS اسم الشبكة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zugriff auf den Standort verweigert – iOS gibt den Netzwerknamen nicht heraus."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Location access is denied — iOS does not reveal the network name."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Acceso a la ubicación denegado: iOS no facilita el nombre de la red."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Accès à la localisation refusé — iOS ne communique pas le nom du réseau."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "लोकेशन एक्सेस की अनुमति नहीं है — iOS नेटवर्क का नाम नहीं देता।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Accesso alla posizione negato: iOS non fornisce il nome della rete."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "位置情報へのアクセスが許可されていないため、iOS はネットワーク名を返しません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "위치 정보 접근이 허용되지 않아 iOS가 네트워크 이름을 제공하지 않아요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Acesso à localização negado: o iOS não fornece o nome da rede."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Konum erişimi reddedildi — iOS ağ adını vermiyor."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "定位访问被拒绝，iOS 不会提供网络名称。"
          }
        }
      }
    },
    "Доступ к локальной сети активен.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الوصول إلى الشبكة المحلية مُفعّل."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zugriff auf das lokale Netzwerk ist aktiv."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Local network access is active."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El acceso a la red local está activo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'accès au réseau local est actif."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "स्थानीय नेटवर्क तक पहुँच सक्रिय है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Accesso alla rete locale attivo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ローカルネットワークへのアクセスが有効です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "로컬 네트워크 접근이 활성화되었습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O acesso à rede local está ativo."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yerel ağ erişimi etkin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "本地网络访问已启用。"
          }
        }
      }
    },
    "Доступ к локальной сети не подтверждён — разрешите его в Настройках iOS.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لم يُؤكَّد الوصول إلى الشبكة المحلية — اسمح به في إعدادات iOS."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zugriff auf das lokale Netzwerk nicht bestätigt – erlauben Sie ihn in den iOS-Einstellungen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Local network access not granted — allow it in iOS Settings."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El acceso a la red local no está confirmado: permítelo en los Ajustes de iOS."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'accès au réseau local n'est pas confirmé — autorisez-le dans les Réglages d'iOS."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "स्थानीय नेटवर्क तक पहुँच सत्यापित नहीं — इसे iOS सेटिंग्स में अनुमति दें।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Accesso alla rete locale non confermato — autorizzalo nelle Impostazioni di iOS."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ローカルネットワークへのアクセスが確認できません — iOS の設定で許可してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "로컬 네트워크 접근이 확인되지 않았습니다 — iOS 설정에서 허용하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O acesso à rede local não foi confirmado — autorize-o nos Ajustes do iOS."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yerel ağ erişimi onaylanmadı — iOS Ayarlar'dan izin verin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "本地网络访问未获授权 — 请在 iOS 设置中允许。"
          }
        }
      }
    },
