    "Провайдер подменил ответ страницей блокировки.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "استبدل المزوّد الاستجابة بصفحة حجب."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Anbieter hat die Antwort durch eine Sperrseite ersetzt."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The provider replaced the response with a block page."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El proveedor sustituyó la respuesta por una página de bloqueo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le fournisseur a remplacé la réponse par une page de blocage."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "प्रदाता ने उत्तर को ब्लॉक पेज से बदल दिया।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il provider ha sostituito la risposta con una pagina di blocco."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "プロバイダーが応答をブロックページに差し替えました。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "제공자가 응답을 차단 페이지로 변조했습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O provedor substituiu a resposta por uma página de bloqueio."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sağlayıcı, yanıtı bir engelleme sayfasıyla değiştirdi."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "运营商用拦截页面替换了响应。"
          }
        }
      }
    },
    "Провайдерский резолвер вернул другой адрес, чем эталонный. Это типичный признак DNS-подмены.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أعاد محلّل المزوّد عنواناً مختلفاً عن المرجعي. هذه علامة نموذجية على تزوير DNS."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Resolver des Anbieters hat eine andere Adresse zurückgegeben als der Referenz-Resolver. Das ist ein typisches Anzeichen für DNS-Fälschung."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The provider's resolver returned a different address than the reference one. This is a typical sign of DNS spoofing."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El resolutor del proveedor devolvió una dirección distinta a la de referencia. Es un indicio típico de falsificación de DNS."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le résolveur du fournisseur a renvoyé une adresse différente de celle de la référence. C'est un signe typique de falsification DNS."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "प्रदाता के रिज़ॉल्वर ने संदर्भ से भिन्न पता लौटाया। यह DNS छेड़छाड़ का सामान्य संकेत है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il resolver del provider ha restituito un indirizzo diverso da quello di riferimento. È un segno tipico di alterazione DNS."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "プロバイダーのリゾルバが基準と異なるアドレスを返しました。これは DNS 改ざんの典型的な兆候です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "제공자 리졸버가 기준과 다른 주소를 반환했습니다. 이는 전형적인 DNS 변조 징후입니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O resolvedor do provedor retornou um endereço diferente do de referência. Esse é um sinal típico de adulteração de DNS."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sağlayıcının çözümleyicisi, referanstan farklı bir adres döndürdü. Bu, DNS sahtekârlığının tipik bir belirtisidir."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "运营商的解析器返回了与参照不同的地址。这是 DNS 篡改的典型迹象。"
          }
        }
      }
    },
    "Провайдеры, сервисы, push-уведомления": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "مزودو الخدمة والخدمات والإشعارات الفورية"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Anbieter, Dienste, Push-Mitteilungen"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Providers, services, push notifications"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Operadores, servicios, notificaciones push"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Opérateurs, services, notifications push"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "प्रोवाइडर, सेवाएँ, पुश सूचनाएँ"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Provider, servizi, notifiche push"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "プロバイダ、サービス、プッシュ通知"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "통신사, 서비스, 푸시 알림"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Provedores, serviços, notificações push"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sağlayıcılar, servisler, anlık bildirimler"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "运营商、服务、推送通知"
          }
        }
      }
    },
    "Проверим IP по спискам DNSBL — тем самым, по которым почтовые серверы решают, принимать ли письмо.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سنفحص عنوان IP في قوائم DNSBL التي تعتمد عليها خوادم البريد لقبول الرسائل."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Prüft die IP gegen DNSBL-Listen – jene, nach denen Mailserver über die Annahme entscheiden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We'll check the IP against DNSBL lists — the ones mail servers use to decide whether to accept a message."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Comprobaremos la IP en listas DNSBL, las que usan los servidores de correo para aceptar o no un mensaje."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nous vérifierons l'IP dans les listes DNSBL, celles dont les serveurs de messagerie se servent pour accepter un message."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "हम IP को DNSBL सूचियों में जाँचेंगे — वही जिनसे मेल सर्वर तय करते हैं कि संदेश स्वीकारें या नहीं।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Controlleremo l'IP nelle liste DNSBL, quelle con cui i server di posta decidono se accettare un messaggio."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "メールサーバーが受信可否を判断する DNSBL リストで IP を照会します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "메일 서버가 수신 여부를 판단할 때 쓰는 DNSBL 목록에서 IP를 조회합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Vamos verificar o IP em listas DNSBL — as que os servidores de e-mail usam para aceitar ou não uma mensagem."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "IP'yi, posta sunucularının bir iletiyi kabul edip etmeyeceğine karar verdiği DNSBL listelerinde ararız."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在 DNSBL 名单中查询该 IP——邮件服务器正是据此决定是否收信。"
          }
        }
      }
    },
    "Проверим, какие порты хоста принимают соединения, и подпишем известные службы.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سنفحص المنافذ التي تقبل الاتصالات على المضيف ونسمّي الخدمات المعروفة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Prüft, welche Ports des Hosts Verbindungen annehmen, und benennt bekannte Dienste."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We'll check which of the host's ports accept connections and label the known services."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Comprobaremos qué puertos del host aceptan conexiones y etiquetaremos los servicios conocidos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nous vérifierons quels ports de l'hôte acceptent les connexions et nommerons les services connus."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "हम जाँचेंगे कि होस्ट के कौन-से पोर्ट कनेक्शन स्वीकारते हैं और ज्ञात सेवाएँ नाम से दिखाएंगे।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Verificheremo quali porte dell'host accettano connessioni ed etichetteremo i servizi noti."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ホストのどのポートが接続を受け付けるかを調べ、既知のサービス名を添えます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "호스트의 어떤 포트가 연결을 받는지 확인하고 알려진 서비스 이름을 붙입니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Vamos verificar quais portas do host aceitam conexões e rotular os serviços conhecidos."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ana bilgisayarın hangi portlarının bağlantı kabul ettiğini kontrol eder ve bilinen servisleri etiketleriz."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "检查主机哪些端口接受连接，并标注已知服务。"
          }
        }
      }
    },
    "Проверить": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
