    "%@ недоступен — 100%% потерь.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ غير متاح — فقد 100%% من الحزم."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ ist nicht erreichbar – 100%% Paketverlust."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ is unreachable — 100%% packet loss."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ no está accesible: 100 %% de pérdida."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ est inaccessible — 100 %% de perte."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ अनुपलब्ध — 100%% पैकेट खोए।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ non è raggiungibile — 100%% di perdita."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ に接続できません（パケットロス 100%%）。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@에 연결할 수 없어요 — 손실 100%%."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ está inacessível — 100%% de perda."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ erişilemiyor — %%100 paket kaybı."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 不可达 — 丢包 100%%。"
          }
        }
      }
    },
