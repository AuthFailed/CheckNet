    "Даже контрольный адрес недоступен — проверьте подключение.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "حتى العنوان المرجعي غير متاح — تحقّق من الاتصال."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Selbst die Kontrolladresse ist nicht erreichbar – prüfen Sie Ihre Verbindung."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Even the control address is unreachable — check your connection."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ni siquiera la dirección de control está disponible: revisa tu conexión."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Même l'adresse de contrôle est inaccessible — vérifiez votre connexion."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यहाँ तक कि नियंत्रण पता भी उपलब्ध नहीं है — अपना कनेक्शन जाँचें।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Anche l'indirizzo di controllo non è raggiungibile — verifica la connessione."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "基準アドレスにも到達できません — 接続を確認してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기준 주소조차 접속할 수 없습니다 — 연결을 확인하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Até o endereço de controle está inacessível — verifique sua conexão."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kontrol adresi bile erişilemiyor — bağlantınızı kontrol edin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "连控制地址都无法访问 — 请检查网络连接。"
          }
        }
      }
    },
