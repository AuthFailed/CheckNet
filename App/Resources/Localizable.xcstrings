    "Провайдер подменил ответ страницей блокировки.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "استبدل المزوّد الاستجابة بصفحة حجب."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Anbieter hat die Antwort durch eine Sperrseite ersetzt."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The provider replaced the response with a block page."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El proveedor sustituyó la respuesta por una página de bloqueo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le fournisseur a remplacé la réponse par une page de blocage."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "प्रदाता ने उत्तर को ब्लॉक पेज से बदल दिया।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il provider ha sostituito la risposta con una pagina di blocco."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "プロバイダーが応答をブロックページに差し替えました。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "제공자가 응답을 차단 페이지로 변조했습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O provedor substituiu a resposta por uma página de bloqueio."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sağlayıcı, yanıtı bir engelleme sayfasıyla değiştirdi."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "运营商用拦截页面替换了响应。"
          }
        }
      }
    },
    "Провайдерский резолвер вернул другой адрес, чем эталонный. Это типичный признак DNS-подмены.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أعاد محلّل المزوّد عنواناً مختلفاً عن المرجعي. هذه علامة نموذجية على تزوير DNS."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Resolver des Anbieters hat eine andere Adresse zurückgegeben als der Referenz-Resolver. Das ist ein typisches Anzeichen für DNS-Fälschung."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The provider's resolver returned a different address than the reference one. This is a typical sign of DNS spoofing."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El resolutor del proveedor devolvió una dirección distinta a la de referencia. Es un indicio típico de falsificación de DNS."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le résolveur du fournisseur a renvoyé une adresse différente de celle de la référence. C'est un signe typique de falsification DNS."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "प्रदाता के रिज़ॉल्वर ने संदर्भ से भिन्न पता लौटाया। यह DNS छेड़छाड़ का सामान्य संकेत है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il resolver del provider ha restituito un indirizzo diverso da quello di riferimento. È un segno tipico di alterazione DNS."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "プロバイダーのリゾルバが基準と異なるアドレスを返しました。これは DNS 改ざんの典型的な兆候です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "제공자 리졸버가 기준과 다른 주소를 반환했습니다. 이는 전형적인 DNS 변조 징후입니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O resolvedor do provedor retornou um endereço diferente do de referência. Esse é um sinal típico de adulteração de DNS."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sağlayıcının çözümleyicisi, referanstan farklı bir adres döndürdü. Bu, DNS sahtekârlığının tipik bir belirtisidir."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "运营商的解析器返回了与参照不同的地址。这是 DNS 篡改的典型迹象。"
          }
        }
      }
    },
