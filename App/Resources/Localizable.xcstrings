    "Два и более приватных маршрутизатора на пути — вероятен Double NAT.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يوجد موجّهان خاصان أو أكثر على المسار — يُرجَّح Double NAT."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zwei oder mehr private Router auf dem Pfad – wahrscheinlich Double NAT."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Two or more private routers on the path — Double NAT is likely."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Dos o más routers privados en la ruta: probable Double NAT."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Deux routeurs privés ou plus sur le trajet — un Double NAT est probable."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "मार्ग पर दो या अधिक निजी राउटर — संभवतः Double NAT।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Due o più router privati lungo il percorso — probabile Double NAT."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "経路上にプライベートルーターが 2 台以上あります — Double NAT の可能性があります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "경로에 사설 라우터가 두 개 이상 있습니다 — Double NAT일 가능성이 높습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Dois ou mais roteadores privados no caminho — provável Double NAT."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yolda iki veya daha fazla özel yönlendirici var — muhtemelen Double NAT."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "路径上有两个或更多私有路由器 — 很可能是双重 NAT。"
          }
        }
      }
    },
