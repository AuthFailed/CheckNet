    "Путь ограничивает MTU ниже 1500 — вероятны туннель/VPN/PPPoE.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يقيّد المسار MTU دون 1500 — يُرجَّح وجود نفق/VPN/PPPoE."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Pfad begrenzt die MTU auf unter 1500 – wahrscheinlich Tunnel/VPN/PPPoE."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The path limits MTU below 1500 — a tunnel/VPN/PPPoE is likely."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La ruta limita el MTU por debajo de 1500: probable túnel/VPN/PPPoE."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le trajet limite le MTU en dessous de 1500 — un tunnel/VPN/PPPoE est probable."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "मार्ग MTU को 1500 से नीचे सीमित करता है — संभवतः टनल/VPN/PPPoE।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il percorso limita l'MTU sotto 1500 — probabile tunnel/VPN/PPPoE."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "経路が MTU を 1500 未満に制限しています — トンネル/VPN/PPPoE の可能性があります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "경로가 MTU를 1500 미만으로 제한합니다 — 터널/VPN/PPPoE일 가능성이 높습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O caminho limita o MTU abaixo de 1500 — provável túnel/VPN/PPPoE."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yol, MTU'yu 1500'ün altına düşürüyor — muhtemelen tünel/VPN/PPPoE."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "路径将 MTU 限制在 1500 以下 — 很可能存在隧道/VPN/PPPoE。"
          }
        }
      }
    },
