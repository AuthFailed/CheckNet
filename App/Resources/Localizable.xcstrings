    "Будет проверено узлов: %lld. Каталог от %@.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سيتم فحص %lld عقدة. الدليل بتاريخ %@."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Es werden %lld Hosts geprüft. Katalog vom %@."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld hosts will be checked. Catalog from %@."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se comprobarán %lld hosts. Catálogo del %@."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Hôtes à vérifier : %lld. Catalogue du %@."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld नोड जाँचे जाएँगे। सूची %@ की।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Nodi da verificare: %lld. Elenco del %@."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "確認するホスト数：%lld。カタログの更新日：%@。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "확인할 호스트: %lld개. 카탈로그 기준일: %@."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Nós a serem verificados: %lld. Catálogo de %@."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Будет проверено узлов: %1$lld. Каталог от %2$@."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld düğüm denetlenecek. Katalog tarihi: %@."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将检测 %lld 个节点。目录版本：%@。"
          }
        }
      }
    },
