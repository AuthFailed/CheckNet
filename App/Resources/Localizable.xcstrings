    "Уведомления о падении будут запрошены при запуске.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سيُطلب إذن إشعارات التعطّل عند التشغيل."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Benachrichtigungen bei Ausfällen werden beim Start angefordert."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Downtime notifications will be requested on launch."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los avisos de caída se solicitarán al iniciar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les notifications de panne seront demandées au lancement."
          }
        },
        "hi": {
