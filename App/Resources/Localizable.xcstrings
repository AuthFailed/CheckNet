    "Ответ отличается от эталонного — содержимое подменяется.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الاستجابة تختلف عن المرجعية — يجري استبدال المحتوى."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Antwort weicht von der Referenz ab – der Inhalt wird ersetzt."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The response differs from the reference — the content is being substituted."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La respuesta difiere de la de referencia: el contenido se sustituye."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La réponse diffère de la référence — le contenu est remplacé."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "जवाब संदर्भ से अलग है — सामग्री बदली जा रही है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La risposta è diversa da quella di riferimento: il contenuto viene sostituito."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "応答が対照と異なります。内容が差し替えられています。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "응답이 대조와 달라요. 내용이 바뀌고 있어요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A resposta é diferente da de referência: o conteúdo está sendo substituído."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yanıt referanstan farklı — içerik değiştiriliyor."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "响应与参照不同，内容被替换。"
          }
        }
      }
    },
