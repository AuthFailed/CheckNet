    "Промежуточные результаты. Можно отключить весь список или отдельные поля в каждом элементе.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "النتائج الوسيطة. يمكن إيقاف القائمة بالكامل أو حقول مفردة في كل عنصر."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zwischenergebnisse. Du kannst die ganze Liste oder einzelne Felder in jedem Eintrag deaktivieren."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Interim results. You can turn off the whole list or individual fields in each entry."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Resultados intermedios. Puedes desactivar toda la lista o campos concretos de cada elemento."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Résultats intermédiaires. Vous pouvez désactiver toute la liste ou certains champs de chaque élément."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "मध्यवर्ती परिणाम। पूरी सूची या हर आइटम के अलग-अलग फ़ील्ड बंद किए जा सकते हैं।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Risultati intermedi. Puoi disattivare l’intero elenco o singoli campi di ogni elemento."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "途中経過です。リスト全体をオフにすることも、各項目の個別のフィールドをオフにすることもできます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "중간 결과예요. 목록 전체를 끄거나 각 항목의 개별 필드를 끌 수 있어요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Resultados parciais. É possível desativar a lista inteira ou campos específicos de cada item."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ara sonuçlar. Listenin tamamını ya da her ögedeki tek tek alanları kapatabilirsiniz."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "中间结果。可关闭整个列表，或每项中的个别字段。"
          }
        }
      }
    },
