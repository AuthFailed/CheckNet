    "Пока не выполнен вход, проверки ниже могут ошибаться.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "قبل تسجيل الدخول إلى الشبكة قد تعطي الفحوص أدناه نتائج خاطئة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Solange du dich nicht angemeldet hast, können die Prüfungen unten falsch sein."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Until you sign in, the checks below may be wrong."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mientras no se complete el inicio de sesión en la red, las comprobaciones de abajo pueden ser erróneas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tant que la connexion au réseau n’est pas validée, les vérifications ci-dessous peuvent être faussées."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "जब तक लॉग इन पूरा नहीं होता, नीचे की जाँचें ग़लत हो सकती हैं।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Finché non hai eseguito l’accesso alla rete, le verifiche qui sotto possono risultare inesatte."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サインインが完了するまで、以下のチェックは正しく判定できないことがあります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "로그인이 끝나기 전에는 아래 확인 결과가 정확하지 않을 수 있어요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Enquanto o acesso à rede não for feito, as verificações abaixo podem apresentar erros."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ağ girişi yapılmadan aşağıdaki denetimler yanlış sonuç verebilir."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在未完成登录前，以下检测结果可能不准确。"
          }
        }
      }
    },
