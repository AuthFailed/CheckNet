          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "왼쪽에 모든 검사가 있어요. 실행할 검사를 선택하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "À esquerda estão todas as verificações. Escolha uma para executá-la."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Solda tüm testler yer alır. Çalıştırmak için birini seçin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "左侧是所有检查。选择任意一项即可运行。"
          }
        }
      }
    },
