    "Фоновый монитор доступности хостов: периодически пингует и ведёт историю аптайма.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "مراقب توفّر المضيفين في الخلفية: يجري ping دورياً ويحتفظ بسجل وقت التشغيل."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Hintergrund-Monitor für die Erreichbarkeit von Hosts: pingt regelmäßig und führt einen Uptime-Verlauf."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Background host-availability monitor: pings periodically and keeps an uptime history."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Monitor de disponibilidad de hosts en segundo plano: hace ping periódicamente y lleva un historial de uptime."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Moniteur de disponibilité des hôtes en arrière-plan : ping périodiquement et tient un historique de la disponibilité."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "होस्ट उपलब्धता का बैकग्राउंड मॉनिटर: समय-समय पर ping करता है और अपटाइम इतिहास रखता है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Monitor in background della raggiungibilità degli host: esegue periodicamente il ping e tiene una cronologia dell'uptime."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ホストの到達性をバックグラウンドで監視します：定期的に ping を送信し、稼働時間の履歴を記録します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "호스트 접속 가능 여부를 백그라운드에서 모니터링합니다: 주기적으로 ping을 보내고 가동 시간 기록을 유지합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Monitor de disponibilidade de hosts em segundo plano: faz ping periodicamente e mantém um histórico de uptime."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sunucu erişilebilirliği için arka plan izleyici: düzenli olarak ping atar ve çalışma süresi geçmişini tutar."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "后台主机可用性监控：定期 ping 并记录在线时长历史。"
          }
        }
      }
    },
