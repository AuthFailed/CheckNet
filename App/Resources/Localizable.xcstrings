    "Системный ответ указывает в приватную сеть — инъекция.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تشير استجابة النظام إلى شبكة خاصة — حقن."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Systemantwort verweist auf ein privates Netzwerk – Injektion."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The system response points to a private network — injection."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La respuesta del sistema apunta a una red privada: inyección."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La réponse système pointe vers un réseau privé — injection."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सिस्टम उत्तर निजी नेटवर्क की ओर इशारा करता है — इंजेक्शन।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La risposta di sistema punta a una rete privata — iniezione."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "システムの応答がプライベートネットワークを指しています — インジェクションです。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "시스템 응답이 사설 네트워크를 가리킵니다 — 주입입니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A resposta do sistema aponta para uma rede privada — injeção."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sistem yanıtı özel bir ağa işaret ediyor — enjeksiyon."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "系统响应指向私有网络 — 存在注入。"
          }
        }
      }
    },
