    "Контрольная страница вернулась без изменений — перехвата нет.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "عادت صفحة التحكّم دون تغيير — لا يوجد اعتراض."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Kontrollseite kam unverändert zurück – nichts fängt sie ab."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The control page came back unchanged — nothing is intercepting it."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La página de control se devolvió sin cambios: no hay interceptación."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La page de contrôle est revenue inchangée — aucune interception."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कंट्रोल पेज बिना बदलाव के लौटा — कोई इंटरसेप्शन नहीं।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
