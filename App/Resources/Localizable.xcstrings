    "TLS-соединение с «запрещённым» именем проходит нормально.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اتصال TLS باسم «محظور» يتم بنجاح."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
