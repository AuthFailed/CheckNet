    "Реальное рукопожатие Chrome: GREASE, ALPS, порядок расширений Chromium.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تبادل تحية Chrome حقيقي: GREASE وALPS وترتيب امتدادات Chromium."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Echter Chrome-Handshake: GREASE, ALPS, Erweiterungsreihenfolge von Chromium."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A real Chrome handshake: GREASE, ALPS, Chromium’s extension order."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Handshake real de Chrome: GREASE, ALPS, orden de las extensiones de Chromium."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vrai handshake Chrome : GREASE, ALPS, ordre des extensions Chromium."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Chrome का असली हैंडशेक: GREASE, ALPS, Chromium का एक्सटेंशन क्रम।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Handshake reale di Chrome: GREASE, ALPS, ordine delle estensioni di Chromium."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Chrome の実際のハンドシェイク: GREASE、ALPS、Chromium の拡張の順序。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Chrome의 실제 핸드셰이크: GREASE, ALPS, Chromium의 확장 순서."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Handshake real do Chrome: GREASE, ALPS, ordem das extensões do Chromium."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gerçek Chrome el sıkışması: GREASE, ALPS, Chromium uzantı sırası."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Chrome 的真实握手：GREASE、ALPS、Chromium 的扩展顺序。"
          }
        }
      }
    },
    "Реальное рукопожатие Firefox: без GREASE-cipher, свой набор групп и расширений.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تبادل تحية Firefox حقيقي: بدون GREASE-cipher، بمجموعة مجموعات وامتدادات خاصة به."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Echter Firefox-Handshake: kein GREASE-Cipher, eigene Gruppen und Erweiterungen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A real Firefox handshake: no GREASE cipher, its own set of groups and extensions."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Handshake real de Firefox: sin GREASE-cipher, con su propio conjunto de grupos y extensiones."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vrai handshake Firefox : sans GREASE-cipher, jeu de groupes et d’extensions spécifique."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Firefox का असली हैंडशेक: GREASE-cipher के बिना, अपने ही ग्रुप और एक्सटेंशन।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Handshake reale di Firefox: senza cifrario GREASE, con gruppi ed estensioni propri."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Firefox の実際のハンドシェイク: GREASE 暗号なし、独自のグループと拡張のセット。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Firefox의 실제 핸드셰이크: GREASE 암호 없음, 고유한 그룹과 확장 구성."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Handshake real do Firefox: sem cifra GREASE, com grupos e extensões próprios."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gerçek Firefox el sıkışması: GREASE-cipher yok, kendine ait grup ve uzantı kümesi."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Firefox 的真实握手：没有 GREASE cipher，有自己的组和扩展集合。"
          }
        }
      }
    },
