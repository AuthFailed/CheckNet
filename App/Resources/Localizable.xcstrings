    "Запускает одну проверку ограничений и возвращает вердикт с подробностями.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يشغّل فحصًا واحدًا للقيود ويعيد الحكم مع التفاصيل."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Führt eine einzelne Sperrprüfung aus und liefert einen Befund mit Details."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Runs a single restriction check and returns a verdict with details."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ejecuta una comprobación de restricciones y devuelve un veredicto con los detalles."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lance une vérification des restrictions et renvoie un verdict détaillé."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "प्रतिबंध की एक जाँच चलाता है और विवरण सहित निष्कर्ष देता है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Esegue una singola verifica delle restrizioni e restituisce il verdetto con i dettagli."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "制限のチェックを1つ実行し、判定と詳細を返します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "제한 확인을 하나 실행하고 판정과 세부 정보를 알려줘요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Executa uma verificação de restrições e retorna o veredito com os detalhes."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tek bir kısıtlama denetimi çalıştırır ve ayrıntılarıyla birlikte bir karar döndürür."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "运行一项限制检测，并返回带详情的结论。"
          }
        }
      }
    },
