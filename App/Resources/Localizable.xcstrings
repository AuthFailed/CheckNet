    "Только https. Исключение — localhost, чтобы можно было проверить приём локально.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "https فقط. والاستثناء الوحيد هو localhost لإتاحة اختبار الاستقبال محليًا."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nur HTTPS. Ausnahme ist localhost, damit du den Empfang lokal testen kannst."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "HTTPS only. The exception is localhost, so you can test receiving locally."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Solo HTTPS. La única excepción es localhost, para poder probar la recepción en local."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "HTTPS uniquement. Seule exception : localhost, pour pouvoir tester la réception en local."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "केवल https। अपवाद — localhost, ताकि रिसेप्शन लोकल में जाँचा जा सके।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Solo https. Unica eccezione: localhost, per poter verificare la ricezione in locale."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "https のみ。例外は localhost で、受信をローカルで確認できるようにするためです。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "https만 가능해요. 로컬에서 수신을 확인할 수 있도록 localhost만 예외예요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Somente https. A exceção é localhost, para testar o recebimento localmente."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yalnızca https. Yerel olarak alımı test edebilmek için tek istisna localhost’tur."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "仅支持 https；localhost 除外，便于在本地测试接收。"
          }
        }
      }
    },
