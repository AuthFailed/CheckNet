    "Стандартный домашний NAT: приватный локальный адрес за одним маршрутизатором.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "NAT منزلي قياسي: عنوان محلي خاص خلف موجّه واحد."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Standard-Heim-NAT: private lokale Adresse hinter einem einzelnen Router."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Standard home NAT: a private local address behind a single router."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "NAT doméstico estándar: dirección local privada tras un único router."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "NAT domestique standard : adresse locale privée derrière un seul routeur."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "मानक होम NAT: एक राउटर के पीछे निजी स्थानीय पता।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "NAT domestico standard: indirizzo locale privato dietro un unico router."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "標準的な家庭用 NAT：単一のルーターの背後にあるプライベートローカルアドレス。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "표준 홈 NAT: 하나의 라우터 뒤 사설 로컬 주소."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "NAT doméstico padrão: endereço local privado atrás de um único roteador."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Standart ev NAT'ı: tek bir yönlendiricinin arkasında özel yerel adres."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "标准家用 NAT：位于单个路由器之后的私有本地地址。"
          }
        }
      }
    },
