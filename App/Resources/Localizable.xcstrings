    "Оператор использует Carrier-Grade NAT — входящие подключения и проброс портов недоступны.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يستخدم المشغّل Carrier-Grade NAT — الاتصالات الواردة وإعادة توجيه المنافذ غير متاحة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Anbieter verwendet Carrier-Grade NAT – eingehende Verbindungen und Portweiterleitung sind nicht möglich."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The carrier uses Carrier-Grade NAT — incoming connections and port forwarding are unavailable."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El operador usa Carrier-Grade NAT: las conexiones entrantes y el reenvío de puertos no están disponibles."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'opérateur utilise un Carrier-Grade NAT — les connexions entrantes et la redirection de ports sont indisponibles."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "ऑपरेटर Carrier-Grade NAT का उपयोग करता है — इनकमिंग कनेक्शन और पोर्ट फ़ॉरवर्डिंग उपलब्ध नहीं हैं।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'operatore usa il Carrier-Grade NAT — le connessioni in entrata e l'inoltro delle porte non sono disponibili."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "通信事業者が Carrier-Grade NAT を使用しています — 着信接続とポート転送は利用できません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "통신사가 Carrier-Grade NAT를 사용합니다 — 인바운드 연결과 포트 포워딩을 사용할 수 없습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A operadora usa Carrier-Grade NAT — conexões de entrada e redirecionamento de portas não estão disponíveis."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Operatör Carrier-Grade NAT kullanıyor — gelen bağlantılar ve port yönlendirme kullanılamaz."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "运营商使用运营商级 NAT — 无法进行入站连接和端口转发。"
          }
        }
      }
    },
    "Определим тип NAT, внешний адрес и наличие CGNAT.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سنحدّد نوع NAT والعنوان الخارجي ووجود CGNAT."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wir bestimmen den NAT-Typ, die externe Adresse und das Vorhandensein von CGNAT."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We'll determine NAT type, external address, and whether CGNAT is present."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Determinaremos el tipo de NAT, la dirección externa y la presencia de CGNAT."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Déterminons le type de NAT, l'adresse externe et la présence d'un CGNAT."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "हम NAT का प्रकार, बाहरी पता और CGNAT की उपस्थिति निर्धारित करेंगे।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Determiniamo il tipo di NAT, l'indirizzo esterno e la presenza di CGNAT."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "NAT のタイプ、外部アドレス、CGNAT の有無を判定します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "NAT 유형, 외부 주소, CGNAT 여부를 확인합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Vamos determinar o tipo de NAT, o endereço externo e a presença de CGNAT."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "NAT türünü, dış adresi ve CGNAT varlığını belirleyelim."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "确定 NAT 类型、外网地址以及是否存在 CGNAT。"
          }
        }
      }
    },
