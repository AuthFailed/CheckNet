    "Нет доступа к имени сети. Нужны Wi-Fi-права приложения и подключение к Wi-Fi.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا يمكن الوصول إلى اسم الشبكة. يلزم منح التطبيق أذونات Wi-Fi والاتصال بشبكة Wi-Fi."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Kein Zugriff auf den Netzwerknamen. Die App benötigt die WLAN-Berechtigung und eine aktive WLAN-Verbindung."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No access to the network name. The app needs the Wi-Fi entitlement and an active Wi-Fi connection."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No hay acceso al nombre de la red. Se requieren los permisos de Wi-Fi de la app y una conexión Wi-Fi."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le nom du réseau est inaccessible. L’app doit disposer des droits Wi-Fi et être connectée en Wi-Fi."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "नेटवर्क का नाम उपलब्ध नहीं है। ऐप को Wi-Fi की अनुमतियाँ और Wi-Fi कनेक्शन चाहिए।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Nome della rete non accessibile. Servono i permessi Wi-Fi dell'app e una connessione Wi-Fi."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ネットワーク名を取得できません。App の Wi-Fi 権限と Wi-Fi 接続が必要です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "네트워크 이름에 접근할 수 없어요. 앱의 Wi-Fi 권한과 Wi-Fi 연결이 필요해요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Sem acesso ao nome da rede. São necessárias as permissões de Wi-Fi do app e uma conexão Wi-Fi."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ağ adına erişilemiyor. Uygulamanın Wi-Fi izinleri ve bir Wi-Fi bağlantısı gerekiyor."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法获取网络名称。需要 App 的 Wi-Fi 权限并已连接到 Wi-Fi。"
          }
        }
      }
    },
