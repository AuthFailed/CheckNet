<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.com.chrsnv.checknet</string>
	</array>
	<!-- Network profiles read the current Wi-Fi SSID, which needs the
	     Access Wi-Fi Information capability. Personal (free) development teams
	     cannot sign it, so it is left OUT to keep the app buildable. When a paid
	     developer account is available, re-add:

	         <key>com.apple.developer.networking.wifi-info</key>
	         <true/>

	     and flip `CurrentNetwork.isSSIDReadable` to `true` in the same commit —
	     that flag is the code-side half of this switch. While it is false the
	     app hides the "check current network" action and explains why, instead
	     of offering a button that cannot work or asking for location it cannot
	     use. -->
</dict>
</plist>
